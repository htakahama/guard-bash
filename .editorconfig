#
# 標準 code style
#
# - EditorConfig
#   https://editorconfig.org/
#
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
# terminal は tab width 8 固定が大半なので変更しない
tab_width = 8
trim_trailing_whitespace = true
# terminal 132 column mode(表示時に line no, separator, mergin 等で 8char 想定)
max_line_length = 124

[*.{c,cpp,c++,h,hpp,hxx}]
indent_size = 2

[*.proto]
indent_size = 4

[*.py]
indent_size = 4

[*.rs]
indent_size = 4

[*.{js,ts}]
indent_size = 4

# md(markdown), cfg(setup.cfg 等) は末尾の space に意味がある
[*.{md,cfg}]
trim_trailing_whitespace = false
max_line_length = unset

# windows bat, 改行は CRLF が安全
[*.bat]
end_of_line = crlf

[*.{xml,json,yaml,toml}]
indent_size = 2

[*.tf]
indent_size = 2


# EOF
